{
  "name": "vite-tauri-template",
  "version": "0.1.0",
  "type": "module",
  "author": "Ni But Crazy",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "preinstall": "npx only-allow pnpm",
    "tauri": "tauri",
    "tauri:dev": "cross-env VITE_REACT_DEVTOOLS=1 tauri dev",
    "tauri:ext": "cross-env TAURI_ENV_EXTENSION=1 tauri dev",
    "tauri:web": "cross-env TAURI_ENV_WEB_INVOKE=1 tauri dev",
    "doc:tauri": "cargo doc --manifest-path src-tauri/Cargo.toml --open --no-deps",
    "version": "git cliff && git add CHANGELOG.md"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "dependencies": {
    "@tanstack/react-router": "^1.169.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@unocss/reset": "^66.6.8",
    "clsx": "^2.1.1",
    "immer": "^11.1.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "use-immer": "^0.11.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.32",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "less": "^4.6.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "unocss": "^66.6.8",
    "vite": "^8.0.10"
  }
}
